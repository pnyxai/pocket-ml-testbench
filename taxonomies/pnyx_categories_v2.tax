// This is a simple aggregation of all dataset used in other taxonomies, used to
// generate a leaderboard-style summary.

pnyx_categories_v2 {

    //--------------------------------------------------------------------------
    //--------------------------------------------------------------------------
    // Roots

    root_c -> reasoning_and_logic;
    // Focuses on reasoning and logic capabilities. It integrates the babisteps 
    // foundational skills with logical reasoning and mathematical thinking

    root_c -> foundational_knowledge;
    // Foundational and domain-specific knowledge: Life Sciences, Physical 
    // Sciences, and Computing.

    root_c -> social_and_ethical;
    // Social, ethical, and human interaction skills: Ethics, Law & Governance, 
    // Business & Economics, and Social Interaction. 

    root_c -> tool_and_instruction_compliance;
    // Covers the ability of a model to understand and execute rules,
    // whether explicit (natural-language instructions / output constraints) or
    // implicit (tool schemas, API call conventions, structured formats).

    root_c -> coding_and_structured_language;
    // It encompasses code generation, debugging, library-level implementation,
    // and rule-heavy structured formats (e.g., regex, markup, grammar-bound languages)
    // Most benchmarks are coding-focused; structured language skills share the same foundations
}

